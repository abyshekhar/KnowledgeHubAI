<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.knowledgehub.ai</string>
    <key>ProgramArguments</key>
    <array>
      <string>/path/to/knowledgehub-ai/.venv/bin/python</string>
      <string>/path/to/knowledgehub-ai/run.py</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/path/to/knowledgehub-ai</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
  </dict>
</plist>

